# =============================================================================
# AskBot — example environment configuration
# Copy this file to `.env` and fill in real values. Never commit your `.env`.
# =============================================================================

# --- Telegram --------------------------------------------------------------
# Bot token from @BotFather
BOT_TOKEN=123456:your-telegram-bot-token
# Numeric Telegram user ID of the admin
ADMIN_ID=000000000
# Private VIP group invite link
GROUP_INVITE_LINK=https://t.me/+your_invite_hash
# VIP group ID for moderation (negative number, e.g. -100xxxxxxxxxx)
VIP_GROUP_ID=0
# Public URL of the bot (used in emails / links)
TELEGRAM_BOT_URL=https://t.me/YourBot

# --- Database --------------------------------------------------------------
# Leave UNSET (or use the sqlite URL below) for local development — the app
# falls back to a local SQLite file automatically.
#
#   Local dev (SQLite):
DATABASE_URL=sqlite:///./ask_bot.db
#
#   Production (PostgreSQL, e.g. Render):
#   DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
#
# Note: Render's "Internal Database URL" may start with `postgres://` — the app
# normalizes that to `postgresql://` automatically, so you can paste it as-is.

# --- VIP membership reconciliation ----------------------------------------
# Delay before removing a lapsed member (default 172800 = 48h)
VIP_SUBSCRIPTION_LAPSE_REMOVAL_DELAY_SECONDS=172800
# How often reconciliation runs (seconds, minimum 5 in code)
VIP_MEMBERSHIP_SYNC_INTERVAL_SECONDS=300
# Grace window after a failed payment (days)
SUBSCRIPTION_PAST_DUE_GRACE_DAYS=3

# --- Stripe ----------------------------------------------------------------
# MOCK_PAYMENT_ENABLED=true  → simulated payments, Stripe is never called
# STRIPE_LIVE_MODE=false     → use TEST keys; true → use LIVE keys
MOCK_PAYMENT_ENABLED=false
STRIPE_LIVE_MODE=false

# TEST mode (Stripe sandbox)
STRIPE_TEST_SECRET_KEY=sk_test_xxx
STRIPE_TEST_PRICE_ID=price_test_xxx
STRIPE_TEST_WEBHOOK_SECRET=whsec_test_xxx

# LIVE mode (real money)
STRIPE_LIVE_SECRET_KEY=sk_live_xxx
STRIPE_LIVE_PRICE_ID=price_live_xxx
STRIPE_LIVE_WEBHOOK_SECRET=whsec_live_xxx

# Where Stripe Billing Portal / Checkout returns the user
STRIPE_PORTAL_RETURN_URL=https://your-app.onrender.com/return
CHECKOUT_BASE_URL=https://your-app.onrender.com

# --- Email (Resend) --------------------------------------------------------
RESEND_API_KEY=re_xxx
EMAIL_FROM=onboarding@resend.dev
EMAIL_NOTIFICATIONS_ENABLED=true
EMAIL_TEST_ENDPOINT_ENABLED=false

# --- Branding --------------------------------------------------------------
BRAND_NAME=VIP Spain Community
